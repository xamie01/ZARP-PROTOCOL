# Copy to .env and fill in. Never commit .env.
# Deployer key — must hold Sepolia ETH for gas. This same wallet receives the
# minted demo balance in `npm run deploy:sepolia`, so connect it in the app to decrypt.
PRIVATE_KEY=0x...

# Sepolia RPC (any provider). e.g. https://sepolia.infura.io/v3/<KEY>
# or the public node: https://ethereum-sepolia-rpc.publicnode.com
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional — enables auto Etherscan verification after deploy.
ETHERSCAN_API_KEY=

# Optional — used by scripts/mint.ts:
#   TOKEN_ADDRESS: the deployed DemoConfidentialToken address to mint from.
#   MINT_TO:       recipient (defaults to the deployer wallet).
#   MINT_AMOUNT:   base units at 6 decimals (defaults to 5000000 = 5.00 zDEMO).
TOKEN_ADDRESS=
MINT_TO=
MINT_AMOUNT=
