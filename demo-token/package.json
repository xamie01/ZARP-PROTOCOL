{
  "name": "zarp-demo-token",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone ERC-7984 confidential token for demonstrating the ZARP app's out-of-registry decrypt flow (FHEVM v0.11).",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "mint:sepolia": "hardhat run scripts/mint.ts --network sepolia",
    "check": "hardhat fhevm check-fhevm-compatibility --network sepolia"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.4.0",
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.2",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@zama-fhe/relayer-sdk": "0.4.1"
  }
}
