# ─────────────────────────────────────────────────────────────────────────────
# ZARP frontend environment
#
# Copy this file to `.env.local` and fill in what you need.
#   cp .env.example .env.local
#
# IMPORTANT: For the SEPOLIA demo you can leave EVERY value blank — sensible
# public defaults are used. Only MAINNET decryption needs RELAYER_API_KEY.
#
# `NEXT_PUBLIC_*` vars are exposed to the browser. Never put a secret in one.
# ─────────────────────────────────────────────────────────────────────────────

# Wallet / RainbowKit -----------------------------------------------------------
# WalletConnect Project ID. Optional but recommended (removes a console warning
# and enables mobile wallets). Free id from https://cloud.reown.com (formerly
# WalletConnect Cloud).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC endpoints -----------------------------------------------------------------
# Optional. Public nodes are used if blank. For production / load, use a keyed
# provider URL (Alchemy or Infura), e.g.
#   https://eth-sepolia.g.alchemy.com/v2/<key>
NEXT_PUBLIC_SEPOLIA_RPC=
NEXT_PUBLIC_MAINNET_RPC=

# Relayer (decryption) ----------------------------------------------------------
# Base PATH of the in-app relayer proxy. Set to `/api/relayer` to enable MAINNET
# decryption (the SDK then routes mainnet through app/api/relayer/[...path]).
# Leave blank for a Sepolia-only deployment.
NEXT_PUBLIC_RELAYER_PROXY_URL=

# Optional Sepolia relayer override. The Sepolia relayer is open (no key), so
# you normally leave this blank.
NEXT_PUBLIC_ZAMA_RELAYER_URL=

# SERVER ONLY — the mainnet relayer API key, injected as `x-api-key` by the
# proxy route. NEVER prefix with NEXT_PUBLIC_ (that would leak it to the
# browser). Request one at https://forms.gle/jq84zEek1oiv3kBz9 . Not needed for
# Sepolia. A leaked key is a financial liability (sponsored txs are billed).
RELAYER_API_KEY=
